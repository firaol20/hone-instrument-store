{
  "name": "hone-instrumental-backend",
  "version": "1.0.0",
  "description": "Express.js backend for Hone Instrumental Store",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --ext ts,js --exec ts-node --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "registry:generate": "ts-node src/scripts/generate-registry.ts",
    "products:upload": "ts-node src/scripts/upload-products.ts",
    "db:seed": "ts-node src/scripts/seed-mongoose.ts",
    "make-admin": "ts-node src/scripts/make-admin.ts",
    "create-admin": "ts-node src/scripts/create-admin.ts",
    "setup-db": "ts-node src/scripts/setup-database.ts",
    "seed-categories": "ts-node src/scripts/seed-categories.ts",
    "seed-products": "ts-node src/scripts/seed-products.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "ecommerce",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.40.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "nodemon": "^3.1.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
